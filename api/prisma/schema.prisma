generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Perfil {
  ADMIN
  GERENTE
  CAIXA
  GARCOM
  COZINHA
}

enum StatusMesa {
  LIVRE
  OCUPADA
  AGUARDANDO_CONTA
}

enum StatusPedido {
  ABERTO
  PAGO
  CANCELADO
}

enum StatusPreparo {
  PENDENTE
  PREPARANDO
  PRONTO
  ENTREGUE
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(100)
  senhaHash String   @map("senha_hash") @db.VarChar(255)
  pin       String?  @unique @db.VarChar(6)
  perfil    Perfil
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  pedidos Pedido[]
  caixas  Caixa[]

  @@map("usuarios")
}

model Produto {
  id         Int      @id @default(autoincrement())
  nome       String   @db.VarChar(100)
  descricao  String?  @db.Text
  preco      Decimal  @db.Decimal(10, 2)
  categoria  String   @db.VarChar(50)
  disponivel Boolean  @default(true)
  urlImagem  String?  @map("url_imagem") @db.VarChar(255)
  criadoEm   DateTime @default(now()) @map("criado_em")

  itensPedido ItemPedido[]

  @@map("produtos")
}

model Mesa {
  id     Int        @id @default(autoincrement())
  numero Int        @unique
  status StatusMesa @default(LIVRE)

  pedidos Pedido[]

  @@map("mesas")
}

model Cliente {
  id          Int      @id @default(autoincrement())
  nome        String   @db.VarChar(100)
  telefone    String   @db.VarChar(20)
  endereco    String?  @db.VarChar(255)
  complemento String?  @db.VarChar(100)
  bairro      String?  @db.VarChar(100)
  cidade      String?  @db.VarChar(100)
  observacao  String?  @db.Text
  criadoEm   DateTime @default(now()) @map("criado_em")

  pedidos Pedido[]

  @@map("clientes")
}

model Pedido {
  id              Int             @id @default(autoincrement())
  mesaId          Int?            @map("mesa_id")
  garcomId        Int             @map("garcom_id")
  clienteId       Int?            @map("cliente_id")
  tipoPedido      TipoPedido      @default(MESA) @map("tipo_pedido")
  statusPedido    StatusPedido    @default(ABERTO) @map("status_pedido")
  statusEntrega   StatusEntrega?  @map("status_entrega")
  formaPagamento  FormaPagamento? @map("forma_pagamento")
  clienteNome     String?         @map("cliente_nome")
  clienteTelefone String?         @map("cliente_telefone")
  enderecoEntrega String?         @map("endereco_entrega") @db.VarChar(300)
  taxaEntrega     Decimal?        @map("taxa_entrega") @db.Decimal(10, 2)
  observacao      String?         @db.Text
  dataCriacao     DateTime        @default(now()) @map("data_criacao")
  total           Decimal?        @db.Decimal(10, 2)
  version         Int             @default(0)

  mesa    Mesa?    @relation(fields: [mesaId], references: [id])
  garcom  Usuario  @relation(fields: [garcomId], references: [id])
  cliente Cliente? @relation(fields: [clienteId], references: [id])
  itens   ItemPedido[]

  @@map("pedidos")
}

model ItemPedido {
  id            Int           @id @default(autoincrement())
  pedidoId      Int           @map("pedido_id")
  produtoId     Int           @map("produto_id")
  quantidade    Int
  precoUnitario Decimal       @db.Decimal(10, 2) @map("preco_unitario")
  observacao    String?       @db.Text
  statusPreparo StatusPreparo @default(PENDENTE) @map("status_preparo")
  criadoEm      DateTime      @default(now()) @map("criado_em")

  pedido  Pedido  @relation(fields: [pedidoId], references: [id])
  produto Produto @relation(fields: [produtoId], references: [id])

  @@map("itens_pedido")
}

enum TipoPedido {
  MESA
  DELIVERY
  RETIRADA
}

enum StatusEntrega {
  RECEBIDO
  CONFIRMADO
  EM_PREPARO
  PRONTO
  SAIU_ENTREGA
  ENTREGUE
  CANCELADO
}

enum FormaPagamento {
  DINHEIRO
  CARTAO_CREDITO
  CARTAO_DEBITO
  PIX
}

enum TipoMovimentacao {
  SANGRIA
  SUPRIMENTO
}

model Caixa {
  id            Int       @id @default(autoincrement())
  operadorId    Int       @map("operador_id")
  valorInicial  Decimal   @db.Decimal(10, 2) @map("valor_inicial")
  valorFinal    Decimal?  @db.Decimal(10, 2) @map("valor_final")
  totalVendas   Decimal?  @db.Decimal(10, 2) @map("total_vendas")
  aberturaEm    DateTime  @default(now()) @map("abertura_em")
  fechamentoEm  DateTime? @map("fechamento_em")
  observacao     String?   @db.Text
  aberto        Boolean   @default(true)

  operador      Usuario          @relation(fields: [operadorId], references: [id])
  movimentacoes MovimentacaoCaixa[]

  @@map("caixas")
}

model MovimentacaoCaixa {
  id          Int              @id @default(autoincrement())
  caixaId     Int              @map("caixa_id")
  tipo        TipoMovimentacao
  valor       Decimal          @db.Decimal(10, 2)
  descricao   String           @db.VarChar(200)
  criadoEm    DateTime         @default(now()) @map("criado_em")

  caixa Caixa @relation(fields: [caixaId], references: [id])

  @@map("movimentacoes_caixa")
}
